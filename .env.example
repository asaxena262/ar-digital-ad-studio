# Copy this file to .env and fill in the values
# The .env file is loaded automatically by server.js on startup

# Port the Node.js server listens on (default: 5000)
PORT=5000

# GitHub Webhook Secret — set the SAME value in GitHub:
# Repo → Settings → Webhooks → Add webhook → Secret
# Generate a strong secret: openssl rand -hex 32
WEBHOOK_SECRET=replace_this_with_a_strong_random_secret

# Node environment
NODE_ENV=production
